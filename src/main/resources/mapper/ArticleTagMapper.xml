<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.coding.mapper.ArticleTagMapper">

    <delete id="deleteByArticleId">
        DELETE FROM article_tag WHERE article_id = #{articleId}
    </delete>

    <select id="selectByArticleId" resultType="com.coding.entity.ArticleTag">
        SELECT id, article_id, tag_id, create_time
        FROM article_tag
        WHERE article_id = #{articleId}
    </select>

</mapper>
