{
  "name": "vue3-element-admin",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite --force --host --mode development",
    "preview": "vite preview",
    "build:prod": "vite build --mode production",
    "deploy": "sh deploy.sh",
    "format": "prettier --write \"src/**/*.{vue,js,ts,json,css,scss,html}\"",
    "format:check": "prettier --check \"src/**/*.{vue,js,ts,json,css,scss,html}\"",
    "format:all": "prettier --write \"./**/*.{vue,js,ts,json,css,scss,html,md}\" --ignore-path .prettierignore",
    "prepare": "husky install"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@toast-ui/editor": "^3.2.2",
    "@vueuse/core": "^13.0.0",
    "axios": "^1.8.4",
    "clipboard": "^2.0.11",
    "dom-to-image": "^2.6.0",
    "echarts": "^5.6.0",
    "element-plus": "^2.9.7",
    "file-saver": "^2.0.5",
    "fuse.js": "^7.1.0",
    "html2canvas": "^1.4.1",
    "js-cookie": "^3.0.5",
    "lodash-es": "^4.17.21",
    "marked": "^15.0.0",
    "moment": "^2.30.1",
    "normalize.css": "^8.0.1",
    "nprogress": "^0.2.0",
    "path-to-regexp": "^8.2.0",
    "pinia": "^3.0.1",
    "qrcode.vue": "^3.6.0",
    "reconnecting-websocket": "^4.4.0",
    "screenfull": "^6.0.2",
    "uuid": "^11.1.0",
    "v-scale-screen": "^2.3.0",
    "vue": "^3.5.13",
    "vue-cropper": "^1.1.4",
    "vue-echarts": "^7.0.3",
    "vue-i18n": "^11.1.2",
    "vue-router": "^4.5.0",
    "vue3-seamless-scroll": "^3.0.2",
    "vuedraggable": "4.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "fast-glob": "^3.3.3",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "path-browserify": "^1.0.1",
    "prettier": "^3.5.3",
    "sass": "^1.86.1",
    "script-loader": "^0.7.2",
    "unplugin-auto-import": "^19.1.2",
    "unplugin-vue-components": "^28.4.1",
    "vite": "^6.2.4",
    "vite-plugin-inspect": "^11.0.0",
    "vite-plugin-svg-icons": "^2.0.1",
    "vite-plugin-vue-devtools": "^7.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "lint-staged": {
    "*.{js,vue,ts}": [
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "esbuild",
      "vue-echarts"
    ],
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "vue-demi",
      "vue-echarts"
    ]
  }
}
